# Runtime
NODE_ENV=development
PORT=4000

# MySQL
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=3306
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_LOGGING=false

# HTTP
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=false
API_RATE_LIMIT_MAX=200
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MINUTES=15

# PageSpeed audit
# Use a random server-only token with at least 32 characters.
AUDIT_API_TOKEN=
AUDIT_ALLOWED_HOSTS=

AUDIT_RATE_LIMIT_MAX=2

# Comma-separated exact hostnames. Do not include protocols, paths or ports.
# Example: paginaswebchavez.netlify.app,plomada.netlify.app
AUDIT_ALLOWED_HOSTS=

AUDIT_RATE_LIMIT_MAX=2
PAGESPEED_API_KEY=